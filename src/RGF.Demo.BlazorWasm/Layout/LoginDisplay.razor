@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Recrovit.RecroGridFramework.Abstraction.Contracts.Services

<AuthorizeView>
    <Authorized>
        <span>Hello, @_recroSec.UserName!</span>
        <button class="@ButtonType" @onclick="BeginLogOut">Log out</button>
    </Authorized>
    <NotAuthorized>
        <a class="@ButtonType" href="authentication/login">Log in</a>
    </NotAuthorized>
</AuthorizeView>

@inject IRecroSecService _recroSec
@inject NavigationManager Navigation
@code {
    [Parameter]
    public string ButtonType { get; set; } = "btn btn-link";

    public void BeginLogOut()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}
