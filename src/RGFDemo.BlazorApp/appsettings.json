{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DistributedSqlServerCache": "Server=(localdb)\\mssqllocaldb;Database=RGF.Demo10;Trusted_Connection=True;MultipleActiveResultSets=false;TrustServerCertificate=True;"
  },
  "Recrovit": {
    "OpenIdConnect": {
      "Host": {
        "CookieName": "__Host-RgfDemoApp-OIDC",
        "EndpointBasePath": "/authentication"
      },
      "Provider": "Duende",
      //"Provider": "EntraId",
      "Providers": {
        "Duende": {
          "Authority": "https://localhost:11900",
          "ClientId": "RGF.DemoApp",
          "ClientSecret": "rgf-demoapp-duende-secret",
          "Scopes": [ "openid", "profile", "offline_access" ],
          "CallbackPath": "/signin-oidc",
          "SignedOutCallbackPath": "/signout-callback-oidc",
          "RemoteSignOutPath": "/signout-oidc",
          "SignedOutRedirectPath": "/",
          "GetClaimsFromUserInfoEndpoint": true,
          "RequireHttpsMetadata": true
        },
        "EntraId": {
          "Authority": "https://login.microsoftonline.com/{TenantId}/v2.0",
          "ClientId": "Client Application ID",
          "ClientSecret": "",
          "Scopes": [ "openid", "profile", "offline_access" ],
          "CallbackPath": "/signin-oidc",
          //"SignedOutCallbackPath": "/signout-callback-oidc",
          //"RemoteSignOutPath": "/signout-oidc",
          "SignedOutRedirectPath": "/",
          "GetClaimsFromUserInfoEndpoint": true,
          "RequireHttpsMetadata": true
        }
      },
      "DownstreamApis": {
        "RgfApi": {
          "BaseUrl": "https://localhost:11913/",
          "Scopes": [ "api://RgfDemo.Api/API.Access" ]
        },
        "UserInfoApi": {
          "BaseUrl": "https://localhost:11900/", //Duende
          "RelativePath": "connect/userinfo", //Duende
          "Scopes": [ "role" ] //Duende
          //"BaseUrl": "https://graph.microsoft.com/", //EntraId
          //"RelativePath": "oidc/userinfo", //EntraId
          //"Scopes": [ "openid", "profile", "email", "User.Read" ] //EntraId
        }
      },
      "TokenCache": {
        "CacheKeyPrefix": "rgf-demoapp-oidc",
        "RefreshBeforeExpirationSeconds": 60
      },
      "Infrastructure": {
        "ForwardedHeadersEnabled": false,
        "DataProtectionKeysPath": ""
      }
    },
    "RecroGridFramework": {
      "API": {
        "ProxyBaseAddress": "https://localhost:44316"
      },
      "RecroDict": {
        "DefaultLanguage": "eng"
      }
    }
  }
}
